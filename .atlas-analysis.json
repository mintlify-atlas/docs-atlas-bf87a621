  "keyFeatures": [
    "Intelligent DITA style guide with embedded rule enforcement",
    "Generic rule library using Schematron abstract patterns",
    "Automatic Schematron schema generation from style guide topics",
    "Discoverable documentation through oXygen tooltips",
    "oXygen framework extension with DIM-specific actions",
    "Sample style guide as starting point for customization",
    "Rule instantiation through DITA markup",
    "Meta-information annotations for element and attribute usage"
  ],
  "publicApiSurface": [
    "gen-rules.xsl - Generate Schematron file from style guide",
    "gen-mappings.xsl - Generate oXygen configuration for discoverable topics",
    "dim2sch.xsl - Convert DIM rules to Schematron",
    "library.sch - Generic Schematron abstract patterns",
    "avoidWordInElement - Pattern to warn about specific words",
    "avoidEndFragment - Pattern to warn about element ending fragments",
    "avoidAttributeInElement - Pattern to warn about forbidden attributes",
    "BusinessRule - Java class for rule management",
    "BusinessRuleLibrary - Repository of available rules",
    "AddBusinessRuleOperation - Operation to add rules to topics",
    "DIM framework actions - oXygen UI actions for rule management"
  ]
